# ============================================
# HCDC-X AI+ Frontend Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values

# Backend API URL (local development)
NEXT_PUBLIC_API_URL=http://localhost:8080

# WebSocket URL (local development)
NEXT_PUBLIC_WS_URL=ws://localhost:8080

# Mapbox Public Token (for geographic heatmap)
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1IjoiaGNkY3giLCJhIjoiY2xxd3Z5bWZ6MDA1eTJqb2F4cHh0b2ZwbyJ9.xxxxxxxxxx

# Cloudinary Cloud Name (for image uploads)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=hcdcx-ai

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxxxx

# Sentry DSN (optional)
NEXT_PUBLIC_SENTRY_DSN=https://xxxxxxxxxxxxxxxx@sentry.io/1234567

# Feature Flags (optional)
NEXT_PUBLIC_ENABLE_AI_SCANNER=true
NEXT_PUBLIC_ENABLE_3D_VISUALIZATION=true
